# Copie este arquivo para .env.deploy e preencha os IDs (iguais nas duas variantes).
# .env.deploy é ignorado pelo git. Sem estes valores, o analytics fica desligado (no-op).

# Microsoft Clarity (heatmaps + gravações) — id do projeto Clarity
VITE_CLARITY_ID=

# Google Analytics 4 (funil) — formato G-XXXXXXXXXX
VITE_GA4_ID=
